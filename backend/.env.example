DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=orbem_db

JWT_SECRET=your_jwt_secret
PORT=5000

EMAIL_USER=you@example.com
EMAIL_PASS=your_smtp_password
EMAIL_FROM=ORBEM Solutions <you@example.com>

# Optional SendGrid fallback; use this if SMTP is blocked in your environment
SENDGRID_API_KEY=your_sendgrid_api_key

# Optional SMTP overrides
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_REQUIRE_TLS=true
